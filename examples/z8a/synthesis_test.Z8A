; ************************************************************************
; * synthesis_test.Z8A - Showcase for MusaX v1.9 LFO Vibrato
; *
; * Demonstrates:
; *   - The three LFO waveforms for pitch modulation (vibrato).
; *   - Channel A cycles through Triangle, Sawtooth, and Square wave vibrato
; *     on a sustained note.
; *   - LFO is set to be slow and wide to make waveforms distinct.
; ************************************************************************

INCLUDE "musax_const.Z8A"

; --- LFO Constants ---
LFODEST_PITCH EQU 1
LFOWAVE_TRI   EQU 0
LFOWAVE_SAW   EQU 1
LFOWAVE_SQR   EQU 2

; --- Instrument IDs ---
INST_ID_VIB_TRI EQU 0
INST_ID_VIB_SAW EQU 1
INST_ID_VIB_SQR EQU 2

; --- Header (14 bytes: 12 channel header + 2 PTR_INST) ---
HDR:
    DEFW    #0600, CH_A
    DEFW    #0600, CH_B
    DEFW    #0600, CH_C
    DEFW    INST_TBL

; --- Instrument pointer table ---
; CMD_INST N -> *(INST_TBL + N*2) -> 16-byte record.
INST_TBL:
    DEFW    INS_VIB_TRI     ; ID 0
    DEFW    INS_VIB_SAW     ; ID 1
    DEFW    INS_VIB_SQR     ; ID 2

; --- Instrument records (16 bytes each) ---
; Layout: Att, Dec, Sus, Rel | LFODest, LFOWave, LFOSpeed, LFOAmp, LFODelay | Flags, Reserved x6

INS_VIB_TRI:                ; Soft attack, full sustain, TRIANGLE vibrato after delay
    DEFB    #0A, #05, #FF, #0A
    DEFB    LFODEST_PITCH, LFOWAVE_TRI, #02, #0C, #14  ; Speed=2, Amp=12, Delay=20
    DEFB    #00, #00, #00, #00, #00, #00, #00

INS_VIB_SAW:                ; Soft attack, full sustain, SAWTOOTH vibrato after delay
    DEFB    #0A, #05, #FF, #0A
    DEFB    LFODEST_PITCH, LFOWAVE_SAW, #02, #0C, #14  ; Speed=2, Amp=12, Delay=20
    DEFB    #00, #00, #00, #00, #00, #00, #00

INS_VIB_SQR:                ; Soft attack, full sustain, SQUARE vibrato after delay
    DEFB    #0A, #05, #FF, #0A
    DEFB    LFODEST_PITCH, LFOWAVE_SQR, #02, #0C, #14  ; Speed=2, Amp=12, Delay=20
    DEFB    #00, #00, #00, #00, #00, #00, #00

; --- Streams ---

CH_A:
    DEFB    CMD_VOLUME, 15
    DEFB    CMD_GATE, 255           ; Legato

.LOOP:
    ; 1. Triangle Wave Vibrato
    DEFB    CMD_INST, INST_ID_VIB_TRI
    DEFB    A4
    DEFW    LEN_W

    ; 2. Sawtooth Wave Vibrato
    DEFB    CMD_INST, INST_ID_VIB_SAW
    DEFB    A4
    DEFW    LEN_W

    ; 3. Square Wave Vibrato
    DEFB    CMD_INST, INST_ID_VIB_SQR
    DEFB    A4
    DEFW    LEN_W

    DEFB    CMD_RESTART
    DEFW    .LOOP

CH_B:
    DEFB    REST
    DEFW    LEN_W
    DEFB    CMD_RESTART
    DEFW    CH_B

CH_C:
    DEFB    REST
    DEFW    LEN_W
    DEFB    CMD_RESTART
    DEFW    CH_C
