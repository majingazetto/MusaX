@TITLE "Sequencer Flow Control Test"
@AUTHOR "Antigravity"
@NAMESPACE SEQTEST

// --- Subroutines ---

PHRASE(SUB_LOW) {
    O4 L16 C D E F
}

// Nested phrase call: SUB_MID calls SUB_LOW
PHRASE(SUB_MID) {
    @CALL(SUB_LOW)
    O5 L16 G A B >C
}

@T120

CH_A:
    @V13 @I0
    START_A:
        // 1. Nested loop test: { { C D }2 E }3
        // Plays: C D C D E, C D C D E, C D C D E
        O5 L16 { { C D }2 E }3
        
        R4
        
        // 2. Subroutine and Nested Subroutine calls
        @CALL(SUB_MID)
        
        R4
        
        // 3. Channel-specific tempo change (Speed up, play, slow down, play)
        @T200
        O4 L8 C D E F
        @T90
        O4 L8 C D E F
        @T120 // restore
        
        R4
        
        // 4. Goto unconditional branch test
        @GOTO(JUMP_TARGET)
        O6 L4 C C C // This should be skipped!
        
    JUMP_TARGET:
        O5 L4 G A
        
        R2
        @RESTART(START_A)
