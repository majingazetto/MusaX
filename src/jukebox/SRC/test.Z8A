;                                       ****************************************
;                                       * MUSAX MINIMAL TEST ROM               *
;                                       * CODED BY ANTIGRAVITY                 *
;                                       ****************************************


; --- ROM OUTPUT                        ----------------------------------------

                OUTPUT  test.raw


; --- MSX SYSTEM CONSTANTS              ----------------------------------------

HTIMI           EQU     #FD9F           ; VBLANK INTERRUPT HOOK ADDRESS
HKEYI           EQU     #FD9A           ; KEYBOARD INTERRUPT HOOK ADDRESS
EXPTBL          EQU     #FCC1           ; BIOS EXPTBL ADDRESS
ENASLT          EQU     #0024           ; BIOS ENABLE SLOT ENTRY POINT
RSLREG          EQU     #0138           ; BIOS READ SLOT REGISTER ENTRY POINT
ENASCR          EQU     #0044           ; BIOS ENABLE SCREEN
CHGMOD          EQU     #005F           ; BIOS CHANGE SCREEN MODE
CLS             EQU     #00C3           ; BIOS CLEAR SCREEN
LDIRVM          EQU     #005C           ; BIOS BLOCK COPY RAM TO VRAM
FORCLR          EQU     #F3E9           ; FOREGROUND COLOR RAM VARIABLE
BAKCLR          EQU     #F3EA           ; BACKGROUND COLOR RAM VARIABLE
CLIKSW          EQU     #F3DB           ; KEY CLICK SWITCH RAM VARIABLE


; --- MSX ROM HEADER                    ----------------------------------------


                ORG     #4000
                DEFB    #41, #42        ; ROM CARTRIDGE SIGNATURE ('AB')
                DEFW    ROMINIT         ; INIT EXECUTION ADDRESS
                DEFS    12              ; RESERVED BYTES


; --- ROM INIT                          ----------------------------------------


; - ROMINIT ----------------------------
; - INITIALIZE SYSTEM AND SOUND ENGINE
; - IN: NONE
; - OUT: NONE
; - CLOBBERS: ALL
; -

ROMINIT         DI
                LD      SP,#F380        ; PAGE 3 STACK POINTER SETUP

                ; DISABLE INTERRUPT HOOKS TEMPORARILY
                LD      A,#C9           ; RET INSTRUCTION
                LD      (HKEYI),A
                LD      (HTIMI),A

                ; SET SLOT PAGE 2 (SAME AS ROM CARTRIDGE PAGE 1)
                CALL    RSLREG
                RRCA
                RRCA
                AND     3
                LD      C,A
                LD      B,0
                LD      HL,EXPTBL
                ADD     HL,BC
                LD      A,(HL)
                AND     #80
                JP      Z,.NOEXP
                OR      C
                LD      C,A
                INC     HL
                INC     HL
                INC     HL
                INC     HL
                LD      A,(HL)
                AND     %00001100
.NOEXP          OR      C
                LD      H,#80
                CALL    ENASLT          ; ENABLE SLOT AT #8000-#BFFF

                ; INITIALIZE SCREEN 1
                LD      A,15            ; WHITE FOREGROUND
                LD      (FORCLR),A
                LD      HL,#0101        ; BLACK BACKGROUND AND BORDER
                LD      (BAKCLR),HL
                XOR     A
                LD      (CLIKSW),A
                LD      A,1             ; SCREEN 1
                CALL    CHGMOD
                CALL    CLS             ; CLEAR SCREEN

                ; LOAD CUSTOM FONT/GRAPHICS BINARY FROM ROM TO VRAM (#0000)
                LD      HL,VRAMDATA
                LD      DE,#0000
                LD      BC,2048         ; 256 CHARACTERS * 8 BYTES
                CALL    LDIRVM

                CALL    ENASCR          ; ENABLE DISPLAY

                ; SHOW LOGO AND WAIT BEFORE PLAYBACK
                CALL    LOGO

                CALL    CLS             ; CLEAR LOGO

                ; INITIALIZE SCREEN 1 COLORS (#2000)
                LD      HL,COLORDAT
                LD      DE,#2000
                LD      BC,32
                CALL    LDIRVM

                ; INITIALIZE GRAPHICAL LAYOUT SKELETON
                CALL    INITLAY

                ; CLEAR RAM VARIABLES AREA (LDIR)
                LD      HL,#E000
                LD      DE,#E001
                LD      BC,#0200        ; CLEAR 512 BYTES OF RAM AT #E000
                LD      (HL),0
                LDIR

                ; INITIALIZE KEYPREV TO #FF (ALL RELEASED)
                LD      A,#FF
                LD      (KEYPREV),A
                LD      (KEYPREV + 1),A
                LD      (KEYPREV + 2),A
                LD      (KEYPREV + 3),A

                ; INITIALIZE MUSAX AUDIO ENGINE
                CALL    MUSINIT

                ; SET FX TABLE POINTER FOR SOUND EFFECTS
                LD      HL,SFXTEST.FX_TABLE
                LD      (FXPTR),HL

                ; HOOK VBLANK INTERRUPT (HTIMI)
                LD      A,#C3           ; JP INSTRUCTION
                LD      (HTIMI),A
                LD      HL,IRQINT
                LD      (HTIMI + 1),HL

                ; START COMPILATION OF SHALOMCASTLE SONG
                LD      HL,SHALOMCASTLE.HEADER
                LD      A,0             ; INFINITE LOOPING LIMIT
                CALL    MUSPLAY         ; PLAY SONG!

                EI                      ; ENABLE INTERRUPTS!


.LOOP           HALT
                CALL    POLLKEY         ; POLL KEYBOARD FOR ACTIONS
                CALL    MUSUPDAT        ; UPDATE ENGINE SEQUENCER
                CALL    DRAWUI          ; DRAW GRAPHICAL DASHBOARD
                JP      .LOOP


; - IRQINT -----------------------------
; - VBLANK IRQ HANDLER FOR MUSAX UPDATE
; - IN: NONE
; - OUT: NONE
; - CLOBBERS: NONE
; -

IRQINT          CALL    MUSCOMM         ; COMMIT REGISTERS TO PHYSICAL PSG
                RET


; - POLLKEY ----------------------------
; - POLLS KEYBOARD FOR TEST SELECTION AND FX TRIGGERING VIA RAM DIRECT MATRIX SCAN
; - IN: NONE
; - OUT: NONE
; - CLOBBERS: ALL
; -

POLLKEY         ; --- PROCESS ROW 0 ---
                LD      A,(KEYPREV)
                LD      B,A
                LD      A,(#FBE5)       ; ROW 0: '0','1','2','3','4','5','6','7'
                LD      C,A
                XOR     B
                AND     B
                LD      D,A             ; D = transitions (1 for press)

                LD      A,C
                LD      (KEYPREV),A     ; Save current Row 0

                ; Check key '1' (Bit 1)
                BIT     1,D
                JR      Z,.NOT1
                LD      HL,SHALOMCASTLE.HEADER
                CALL    .PLAY
                JR      .ROW1

.NOT1           BIT     2,D
                JR      Z,.NOT2
                LD      HL,ADSRTEST.HEADER
                CALL    .PLAY
                JR      .ROW1

.NOT2           BIT     3,D
                JR      Z,.NOT3
                LD      HL,LFOTEST.HEADER
                CALL    .PLAY
                JR      .ROW1

.NOT3           BIT     4,D
                JR      Z,.NOT4
                LD      HL,SEQTEST.HEADER
                CALL    .PLAY
                JR      .ROW1

.NOT4           BIT     5,D
                JR      Z,.NOT5
                LD      HL,MODTEST.HEADER
                CALL    .PLAY
                JR      .ROW1

.NOT5           BIT     6,D
                JR      Z,.NOT6
                LD      HL,SFXTEST.HEADER
                CALL    .PLAY
                JR      .ROW1

.NOT6           BIT     7,D
                JR      Z,.NOT7
                LD      A,0             ; FX_LO (ID 0)
                CALL    FXPLAY
                JR      .ROW1

.NOT7           BIT     0,D             ; '0'
                JR      Z,.ROW1
                LD      A,3             ; FX_TRI (ID 3)
                CALL    FXPLAY

.ROW1           ; --- PROCESS ROW 1 ---
                LD      A,(KEYPREV + 1)
                LD      B,A
                LD      A,(#FBE6)       ; ROW 1: '8','9'
                LD      C,A
                XOR     B
                AND     B
                LD      D,A             ; D = transitions

                LD      A,C
                LD      (KEYPREV + 1),A ; Save current Row 1

                BIT     0,D             ; '8'
                JR      Z,.NOT8
                LD      A,1             ; FX_HI (ID 1)
                CALL    FXPLAY
                JR      .ROW5

.NOT8           BIT     1,D             ; '9'
                JR      Z,.ROW5
                LD      A,2             ; FX_FAN (ID 2)
                CALL    FXPLAY

.ROW5           ; --- PROCESS ROW 5 ---
                LD      A,(KEYPREV + 2)
                LD      B,A
                LD      A,(#FBEA)       ; ROW 5: 'S' BIT 0
                LD      C,A
                XOR     B
                AND     B
                LD      D,A             ; D = TRANSITIONS

                LD      A,C
                LD      (KEYPREV + 2),A ; SAVE CURRENT ROW 5

                BIT     0,D             ; 'S' (BIT 0) - STOP
                JR      Z,.ROW3
                CALL    MUSSTOP

.ROW3           ; --- PROCESS ROW 3 ---
                LD      A,(KEYPREV + 3)
                LD      B,A
                LD      A,(#FBE8)       ; ROW 3: C,D,E,F,G,H,I,J (BITS 0..7)
                LD      C,A
                XOR     B
                AND     B
                LD      D,A             ; D = TRANSITIONS

                LD      A,C
                LD      (KEYPREV + 3),A ; SAVE CURRENT ROW 3

                BIT     0,D             ; 'C' (BIT 0) - PORTA TEST
                JR      Z,.NOTRC
                LD      HL,PORTATST.HEADER
                CALL    .PLAY
                JR      .RROW3

.NOTRC          BIT     1,D             ; 'D' (BIT 1) - DETUNE TEST
                JR      Z,.NOTRD
                LD      HL,DTNTST.HEADER
                CALL    .PLAY
                JR      .RROW3

.NOTRD          BIT     2,D             ; 'E' (BIT 2) - CHORUS TEST
                JR      Z,.NOTRE
                LD      HL,CHORTST.HEADER
                CALL    .PLAY
                JR      .RROW3

.NOTRE          BIT     3,D             ; 'F' (BIT 3) - FADE OUT
                JR      Z,.NOTFD
                LD      A,0             ; TARGET = 0 (SILENCE)
                LD      H,3             ; SPEED = 3 (~85 FRAMES)
                CALL    MUSFADE
                JR      .RROW3

.NOTFD          BIT     6,D             ; 'I' (BIT 6) - FADE IN
                JR      Z,.RROW3
                LD      A,0
                LD      H,255           ; SNAP GLOBAL VOL TO 0
                CALL    MUSFADE
                LD      HL,SHALOMCASTLE.HEADER
                CALL    .PLAY
                LD      A,255           ; TARGET = FULL VOLUME
                LD      H,3             ; SPEED = 3 (~85 FRAMES)
                CALL    MUSFADE

.RROW3          RET


.PLAY           PUSH    HL
                CALL    MUSSTOP
                POP     HL
                LD      A,0             ; loop limit
                CALL    MUSPLAY
                RET


; - LOGO -------------------------------
; - SHOW SPLASH LOGO AND DELAY
; - IN: NONE
; - OUT: NONE
; - CLOBBERS: ALL
; -

LOGO            ; DRAW SPLASH TEXT
                LD      HL,SPLASH
                LD      DE,#1AEE        ; BOTTOM RIGHT CORNER (ROW 23, COL 14)
                CALL    PUTSTR

                ; WAIT 2 SECONDS (120 INTERRUPTS AT 60HZ)
                LD      B,120
                EI                      ; ENABLE INTERRUPTS TO TICK VBLANK
.WAIT           HALT                    ; WAIT FOR NEXT INTERRUPT
                DJNZ    .WAIT
                DI                      ; DISABLE INTERRUPTS
                RET


; - PUTSTR -----------------------------
; - WRITE NULL-TERMINATED STRING TO VRAM
; - IN: HL = STR ADDRESS, DE = VRAM ADDRESS
; - OUT: NONE
; - CLOBBERS: A, HL, DE
; -

PUTSTR          EX      DE,HL
                CALL    SETWRT
                EX      DE,HL
.LOOP           LD      A,(HL)
                OR      A
                RET     Z
                OUT     (#98),A
                INC     HL
                JP      .LOOP


; - SETWRT -----------------------------
; - SET VDP WRITE ADDRESS
; - IN: HL = VRAM ADDRESS (14-BIT)
; - OUT: NONE
; - CLOBBERS: A
; -

SETWRT          LD      A,L
                OUT     (#99),A
                LD      A,H
                OR      #40
                OUT     (#99),A
                RET


; - INITLAY ----------------------------
; - INITIALIZE GRAPHICAL LAYOUT ON SCREEN
; - IN: NONE
; - OUT: NONE
; - CLOBBERS: ALL
; -

INITLAY         ; DRAW HORIZONTAL DIVIDER LINES AT ROWS 1, 9, 17, 19
                LD      HL,#1820        ; ROW 1
                CALL    .DRAWLN
                LD      HL,#1920        ; ROW 9
                CALL    .DRAWLN
                LD      HL,#1A20        ; ROW 17
                CALL    .DRAWLN
                LD      HL,#1A60        ; ROW 19
                CALL    .DRAWLN

                ; RENDER STATIC LAYOUT STRINGS FROM TABLE
                LD      IX,LAYTBL
.LOOP           LD      E,(IX+0)
                LD      D,(IX+1)        ; DE = VRAM ADDRESS
                LD      A,D
                OR      E
                RET     Z               ; END OF TABLE
                
                LD      L,(IX+2)
                LD      H,(IX+3)        ; HL = STRING POINTER
                
                PUSH    IX
                CALL    PUTSTR          ; DRAW STRING AT VRAM DE
                POP     IX
                
                LD      DE,4
                ADD     IX,DE           ; ADVANCE TO NEXT ENTRY
                JP      .LOOP

.DRAWLN         ; HL = VRAM ADDRESS
                CALL    SETWRT
                LD      B,32            ; LINE LENGTH
                LD      A,#81           ; HORIZONTAL DIVIDER CHAR
.L1             OUT     (#98),A
                DJNZ    .L1
                RET


; - DRAWUI -----------------------------
; - DRAW REAL-TIME VARIABLES AND CHANNEL STATES
; - IN: NONE
; - OUT: NONE
; - CLOBBERS: ALL
; -

DRAWUI          ; 1. DRAW SONG NAME
                LD      A,(MUSSTAT)
                OR      A
                JR      Z,.NONE
                
                LD      HL,(SONGPTR)
                LD      IX,SNGNAMTB
.SRCH           LD      E,(IX+0)
                LD      D,(IX+1)
                LD      A,D
                OR      E
                JR      Z,.NONE         ; NOT FOUND
                
                LD      A,L
                CP      E
                JR      NZ,.NEXT
                LD      A,H
                CP      D
                JR      Z,.FOUND
.NEXT           LD      DE,4
                ADD     IX,DE
                JP      .SRCH
.NONE           LD      HL,.SNONE
                JR      .PRTSNG
.FOUND          LD      L,(IX+2)
                LD      H,(IX+3)
.PRTSNG         LD      DE,#1877
                CALL    PUTSTR

                ; 2. DRAW BPM
                CALL    GETBPM          ; A = BPM
                LD      DE,#1897
                CALL    SETWRT
                CALL    DEC2STR         ; PRINTS 3 DIGITS (SPACE PADDED)

                ; 3. DRAW MASTER VOLUME
                LD      DE,#18B7
                CALL    SETWRT
                LD      A,(MUSVOL)
                CALL    PRN2DEC         ; PRINTS 2 DIGITS
                LD      A,"/"
                OUT     (#98),A
                LD      A,"1"
                OUT     (#98),A
                LD      A,"5"
                OUT     (#98),A

                ; 4. DRAW LOOP COUNTER
                LD      DE,#18D7
                CALL    SETWRT
                LD      A,(SONGLOP)
                CALL    PRN2DEC
                LD      A,"/"
                OUT     (#98),A
                LD      A,(SONGLMT)
                OR      A
                JR      NZ,.LMT
                LD      A,"I"
                OUT     (#98),A
                LD      A,"N"
                OUT     (#98),A
                LD      A,"F"
                OUT     (#98),A
                JR      .DNLP
.LMT            LD      A,(SONGLMT)
                CALL    PRN2DEC
                LD      A," "           ; OVERWRITE "F" FROM "INF"
                OUT     (#98),A
.DNLP           

                ; 5. DRAW STATUS
                LD      A,(MUSSTAT)
                BIT     1,A
                JR      NZ,.FAD
                BIT     0,A
                JR      NZ,.PLY
                LD      HL,.SSTOP
                JR      .PRTST
.FAD            LD      HL,.SFAD
                JR      .PRTST
.PLY            LD      HL,.SPLY
.PRTST          LD      DE,#18F7
                CALL    PUTSTR

                ; 6. DRAW FADE
                LD      A,(GLBFADSP)
                OR      A
                JR      NZ,.FADAC
                LD      HL,.SIACT
                LD      DE,#1917
                CALL    PUTSTR
                JR      .DONE
.FADAC          LD      DE,#1917
                CALL    SETWRT
                LD      A,(GLBFADVL)
                CALL    DEC2STR
                LD      A,"/"
                OUT     (#98),A
                LD      A,"2"
                OUT     (#98),A
                LD      A,"5"
                OUT     (#98),A
                LD      A,"5"
                OUT     (#98),A
.DONE           RET

.SNONE          DEFB    "NONE  ", 0
.SSTOP          DEFB    "STOP  ", 0
.SFAD           DEFB    "FADING", 0
.SPLY           DEFB    "PLAY  ", 0
.SIACT          DEFB    "INACTV", 0


; - GETBPM -----------------------------
; - GET INTEGER BPM FROM CHANNEL 0 BPM STEP
; - IN: NONE
; - OUT: A = BPM VALUE
; - CLOBBERS: BC, DE, HL
; -

GETBPM          LD      HL,(CHANNELS + CHBPM)
                ; SHIFT HL RIGHT 4 BITS
                LD      B,4
.S1             SRL     H
                RR      L
                DJNZ    .S1
                
                ; MULTIPLY HL BY 75
                LD      DE,0
                LD      B,75
.M1             EX      HL,DE
                ADD     HL,DE
                EX      HL,DE
                DJNZ    .M1
                
                LD      A,D             ; A = DE / 256
                RET


; - PRN2DEC ----------------------------
; - PRINT 2-DIGIT SPACE-PADDED DECIMAL VALUE TO VRAM
; - IN: A = VALUE (0..99), VRAM ADDRESS SET PRIOR VIA SETWRT
; - OUT: NONE
; - CLOBBERS: A, B
; -

PRN2DEC         LD      B,0
.TENS           SUB     10
                JR      C,.TNSDN
                INC     B
                JR      .TENS
.TNSDN          ADD     A,10
                PUSH    AF
                LD      A,B
                OR      A
                JR      Z,.TNSSP
                ADD     A,"0"
                JR      .TNSWR
.TNSSP          LD      A," "           ; SPACE PADDING FOR TENS
.TNSWR          OUT     (#98),A
                POP     AF
                ADD     A,"0"
                OUT     (#98),A
                RET


; - DEC2STR ----------------------------
; - CONVERT 8-BIT VALUE TO 3-DIGIT SPACE-PADDED ASCII IN VRAM
; - IN: A = VALUE, VRAM ADDRESS MUST BE SET PRIOR VIA SETWRT
; - OUT: NONE
; - CLOBBERS: ALL
; -

DEC2STR         LD      C,A
                ; HUNDREDS
                LD      B,0
.HUND           SUB     100
                JR      C,.HNDDN
                INC     B
                JR      .HUND
.HNDDN          ADD     A,100
                LD      H,A             ; SAVE REMAINDER IN H
                LD      A,B
                OR      A
                JR      Z,.HNDSP
                ADD     A,"0"
                JR      .HNDWR
.HNDSP          LD      A," "           ; SPACE PADDING FOR HUNDREDS
.HNDWR          OUT     (#98),A
                
                ; TENS
                LD      A,H
                LD      B,0
.TENS           SUB     10
                JR      C,.TNSDN
                INC     B
                JR      .TENS
.TNSDN          ADD     A,10
                LD      L,A             ; SAVE ONES IN L
                LD      A,B
                OR      A
                JR      NZ,.TNSVL
                ; IF HUNDREDS WAS SPACE, TENS SHOULD BE SPACE TOO
                LD      A,C
                CP      100
                JR      NC,.TNSVL
                LD      A," "
                JR      .TNSWR
.TNSVL          ADD     A,"0"
.TNSWR          OUT     (#98),A
                
                ; ONES
                LD      A,L
                ADD     A,"0"
                OUT     (#98),A
                RET


; --- INCLUDES                          ----------------------------------------


; --- MUSAX SOUND ENGINE CODE           ----------------------------------------

                DEFINE  _MUSAX_INTEGRATION_

                INCLUDE "../../driver/CONST.Z8A"
                INCLUDE "../../driver/MUSAX.Z8A"
                INCLUDE "../../driver/TABLES.Z8A"


; --- COMPILED SONG DATA                ----------------------------------------

                INCLUDE "TMP/shalomcastle.Z8A"
                INCLUDE "TMP/adsr_test.Z8A"
                INCLUDE "TMP/lfo_test.Z8A"
                INCLUDE "TMP/sfx_priority_test.Z8A"
                INCLUDE "TMP/sequencer_test.Z8A"
                INCLUDE "TMP/modulation_test.Z8A"
                INCLUDE "TMP/porta_test.Z8A"
                INCLUDE "TMP/detune_test.Z8A"
                INCLUDE "TMP/chorus_test.Z8A"


COLORDAT        DEFB    #F1, #F1, #F1, #F1, #F1, #F1, #F1, #F1 ; GROUPS 0-7: WHITE ON BLACK
                DEFB    #F1, #F1, #F1, #F1                     ; GROUPS 8-11: WHITE ON BLACK (UPPERCASE)
                DEFB    #71, #71, #71, #71                     ; GROUPS 12-15: CYAN ON BLACK (LOWERCASE / HIGHLIGHT)
                DEFB    #F1, #F1, #F1, #F1, #71, #71, #F1, #F1 ; GROUPS 16-23: GROUPS 20-21 CYAN (CUSTOM DIGITS)
                DEFB    #F1, #F1, #F1, #F1                     ; GROUPS 24-27: WHITE ON BLACK
                DEFB    #31, #31                               ; GROUPS 28-29: LIGHT GREEN ON BLACK (MUSIC BARS)
                DEFB    #B1, #B1                               ; GROUPS 30-31: LIGHT YELLOW ON BLACK (SFX BARS)

; --- LAYOUT STRINGS
STRTITLE        DEFB    " MUSAX GRAPHICAL JUKEBOX v1.9   ", 0
STRSUB          DEFB    " PLAYLIST         PLAYBACK INFO ", 0
STRPLAY1        DEFB    " ", #A1, ".SHALOMCASTLE   SONG: ", 0
STRPLAY2        DEFB    " ", #A2, ".ADSR_TEST      BPM : ", 0
STRPLAY3        DEFB    " ", #A3, ".LFO_TEST       VOL : ", 0
STRPLAY4        DEFB    " ", #A4, ".SEQ_TEST       LOOP: ", 0
STRPLAY5        DEFB    " ", #A5, ".MOD_TEST       STAT: ", 0
STRPLAY6        DEFB    " ", #A6, ".SFX_PRIORITY   FADE: ", 0
STRCHHDR        DEFB    "CH TY VOL   NOTE INS  PER  STAT ", 0
STRCH0          DEFB    "0A MU ", 0
STRCH1          DEFB    "1B MU ", 0
STRCH2          DEFB    "2C MU ", 0
STRCH3          DEFB    "3A FX ", 0
STRCH4          DEFB    "4B FX ", 0
STRCH5          DEFB    "5C FX ", 0
STRSFX          DEFB    " sfx: ", #A7, ":LO  ", #A8, ":HI  ", #A9, ":FAN  ", #A0, ":TRI  ", 0
STRKEY1         DEFB    " keys: ", #A1, "-", #A6, " PLAY   ", #80, " s STOP ALL   ", 0
STRKEY2         DEFB    "       c PORTA    ", #80, " f FADE OUT   ", 0
STRKEY3         DEFB    "       e CHORUS   ", #80, " i FADE IN    ", 0
STRKEY4         DEFB    "                  ", #80, " d DETUNE     ", 0

; --- LAYOUT TABLE
LAYTBL          DEFW    #1800, STRTITLE
                DEFW    #1840, STRSUB
                DEFW    #1860, STRPLAY1
                DEFW    #1880, STRPLAY2
                DEFW    #18A0, STRPLAY3
                DEFW    #18C0, STRPLAY4
                DEFW    #18E0, STRPLAY5
                DEFW    #1900, STRPLAY6
                DEFW    #1940, STRCHHDR
                DEFW    #1960, STRCH0
                DEFW    #1980, STRCH1
                DEFW    #19A0, STRCH2
                DEFW    #19C0, STRCH3
                DEFW    #19E0, STRCH4
                DEFW    #1A00, STRCH5
                DEFW    #1A40, STRSFX
                DEFW    #1A80, STRKEY1
                DEFW    #1AA0, STRKEY2
                DEFW    #1AC0, STRKEY3
                DEFW    #1AE0, STRKEY4
                DEFW    0               ; END OF TABLE MARKER


; --- SONG NAMES TABLE
SNGNAMTB        DEFW    SHALOMCASTLE.HEADER, .SSHAL
                DEFW    ADSRTEST.HEADER, .SADSR
                DEFW    LFOTEST.HEADER, .SLFO
                DEFW    SEQTEST.HEADER, .SSEQ
                DEFW    MODTEST.HEADER, .SMOD
                DEFW    SFXTEST.HEADER, .SSFX
                DEFW    PORTATST.HEADER, .SPORT
                DEFW    DTNTST.HEADER, .SDTN
                DEFW    CHORTST.HEADER, .SCHOR
                DEFW    0               ; END OF TABLE MARKER

.SSHAL          DEFB    "SHALOM", 0
.SADSR          DEFB    "ADSR  ", 0
.SLFO           DEFB    "LFO   ", 0
.SSEQ           DEFB    "SEQ   ", 0
.SMOD           DEFB    "MOD   ", 0
.SSFX           DEFB    "SFX   ", 0
.SPORT          DEFB    "PORTA ", 0
.SDTN           DEFB    "DETUNE", 0
.SCHOR          DEFB    "CHORUS", 0


SPLASH          DEFB    "MusaX Jukebox v1.9", 0

VRAMDATA        INCBIN  "VRAM.BIN"


; --- ROM PADDING                       ----------------------------------------

                SIZE    32 * 1024
                OUTEND


; --- RAM MEMORY VARIABLES              ----------------------------------------


                ORG     #E000
                INCLUDE "../../driver/VARS.Z8A"
KEYPREV         DEFS    4
